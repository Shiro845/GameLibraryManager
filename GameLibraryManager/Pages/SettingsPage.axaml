<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             Background="#052535"
             x:Class="GameLibraryManager.Pages.SettingsPage">
        <Border BorderThickness="2" BorderBrush="Aqua" CornerRadius="10" Margin="5">
            <Border.Background>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                    <GradientStop Color="#203A43" Offset="0.0"/>
                    <GradientStop Color="#2C5364" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.RowDefinitions>
                   <RowDefinition Height="*"/>
                   <RowDefinition Height="6*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Label HorizontalAlignment="Left">
                        <Viewbox Stretch="Uniform">
                            <TextBlock Text="{DynamicResource Settings}" Margin="5" Foreground="White"/>
                        </Viewbox>
                    </Label>
                </Grid>
                <Viewbox Grid.Row="1" Stretch="Uniform" HorizontalAlignment="Stretch" x:CompileBindings="False">
                    <Grid ColumnDefinitions="*, *">
                        <StackPanel Grid.Row="0">
                            <TextBlock Text="{DynamicResource InterfaceLanguage}" Width="150" Foreground="White"/>
                            <ComboBox SelectedIndex="{Binding SelectedLanguageIndex, Mode=TwoWay}" Width="150" Margin="20, 10, 20, 20"
                                      MaxDropDownHeight="100">
                                <ComboBoxItem Tag="English">English</ComboBoxItem>
                                <ComboBoxItem Tag="Ukrainian">Українська</ComboBoxItem>
                            </ComboBox>
                            <TextBlock Text="{DynamicResource WindowOpacity}" Width="150" Foreground="White"/>
                            <Slider Minimum="0.2" Maximum="1.0"
                                    Value="{Binding WindowOpacity, Mode=TwoWay}" SmallChange="0.05" Margin="20, 0, 20, 0"
                                    Width="150" HorizontalAlignment="Left"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="{DynamicResource Resolution}" Width="150" Foreground="White"/>
                            <ComboBox SelectedIndex="{Binding SelectedResolutionIndex, Mode=TwoWay}" Width="150" Margin="20, 10, 20, 20"
                                      MaxDropDownHeight="100">
                                <ComboBoxItem Tag="1280,720">1280 × 720 (HD)</ComboBoxItem>
                                <ComboBoxItem Tag="1366,768">1366 × 768 (Laptop)</ComboBoxItem>
                                <ComboBoxItem Tag="1600,900">1600 × 900 (HD+)</ComboBoxItem>
                                <ComboBoxItem Tag="1920,1080">1920 × 1080 (Full HD)</ComboBoxItem>
                                <ComboBoxItem Tag="2560,1440">2560 × 1440 (QHD)</ComboBoxItem>
                                <ComboBoxItem Tag="3840,2160">3840 × 2160 (4K)</ComboBoxItem>
                            </ComboBox>
                            <CheckBox Margin="20" Foreground="White"
                                      Content="{DynamicResource Fullscreen}"
                                      IsChecked="{Binding IsFullscreen, Mode=TwoWay}"/>
                        </StackPanel>
                    </Grid>    
                </Viewbox>
            </Grid>
        </Border>
    
</UserControl>