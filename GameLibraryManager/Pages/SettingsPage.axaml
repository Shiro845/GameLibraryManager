<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             Background="#052535"
             x:Class="GameLibraryManager.Pages.SettingsPage">
        <Border BorderThickness="2" BorderBrush="Aqua" CornerRadius="10" Margin="5">
            <Border.Background>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                    <GradientStop Color="#203A43" Offset="0.0"/>
                    <GradientStop Color="#2C5364" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.RowDefinitions>
                   <RowDefinition Height="*"/>
                   <RowDefinition Height="6*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Label HorizontalAlignment="Left">
                        <Viewbox Stretch="Uniform">
                            <TextBlock Text="{DynamicResource Settings}" Margin="5" Foreground="White"/>
                        </Viewbox>
                    </Label>
                </Grid>
                <StackPanel Grid.Row="1">
                    <ComboBox x:Name="LanguageComboBox" 
                              SelectionChanged="LanguageComboBox_SelectionChanged" 
                              Width="150" Margin="20"
                              SelectedIndex="0"> <ComboBoxItem Tag="English">English</ComboBoxItem>
                        <ComboBoxItem Tag="Ukrainian">Українська</ComboBoxItem>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>
    
</UserControl>