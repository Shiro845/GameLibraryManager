<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:gamelibrarymanager="using:GameLibraryManager"
             xmlns:vm="using:GameLibraryManager.ViewModel"
             xmlns:material="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:DataType="vm:MainViewModel"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="720"
             Background="#052535"
             x:Class="GameLibraryManager.Pages.HomePage">
        <Border BorderThickness="2" BorderBrush="Aqua" CornerRadius="10" Margin="5">
            <Border.Background>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                    <GradientStop Color="#203A43" Offset="0.0"/>
                    <GradientStop Color="#2C5364" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.RowDefinitions>
                   <RowDefinition Height="*"/>
                   <RowDefinition Height="5*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Label HorizontalAlignment="Left">
                        <Viewbox Stretch="Uniform">
                            <StackPanel Orientation="Horizontal">
                                <material:MaterialIcon Kind="Home" Foreground="White"/>
                                <TextBlock Text="{DynamicResource Home}" Margin="5" Foreground="White"/>
                            </StackPanel>
                        </Viewbox>
                    </Label>
                </Grid>
                <Grid Grid.Row="1" RowDefinitions=" *, *, 3*, 2*">
                    <Viewbox Grid.Row="0" Stretch="Uniform">
                        <Grid ColumnDefinitions="Auto, 2*, Auto" Width="450">
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{DynamicResource TotalGamesCount}" Foreground="White" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding TotalGamesCount}" Foreground="Pink" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1"/>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{DynamicResource FavouriteGamesCount}" Foreground="White" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding FavouriteGamesCount}" Foreground="Pink" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Viewbox>
                    <Viewbox Grid.Row="1" Stretch="Uniform">
                        <Label FontSize="15" Foreground="Pink" VerticalAlignment="Bottom" HorizontalAlignment="Center" Content="{DynamicResource LaunchSortList}"/>
                    </Viewbox>
                    <Border Grid.Row="2" Margin="5" Background="#253545"
                    BorderThickness="2" BorderBrush="#50ffffff" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding LaunchSortedGames}" x:CompileBindings="False">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <gamelibrarymanager:GameUserControl/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                    <Grid Grid.Row="3" Margin="3, 0, 3, 3">
                        <Border VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                                BorderBrush="OrangeRed" BorderThickness="1" CornerRadius="5">
                            <Button Background="#dd00ffff" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                            HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="5" Click="RandomGame_Click">
                                <Viewbox Stretch="Uniform" Margin="15">
                                    <StackPanel Orientation="Horizontal">
                                        <material:MaterialIcon Kind="Dice5" Foreground="Black" VerticalAlignment="Center" Width="15" Height="15"/>
                                        <TextBlock Text="{DynamicResource RandomGame}" FontSize="10" Margin="0,2,0,0" Foreground="Black"/>
                                    </StackPanel>
                                </Viewbox>
                            </Button>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>        
        </Border>
</UserControl>
