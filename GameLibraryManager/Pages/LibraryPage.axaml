<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:gamelibrarymanager="using:GameLibraryManager"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:GameLibraryManager.ViewModel"
             xmlns:material="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:DataType="vm:MainViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             Background="#052535"
             x:Class="GameLibraryManager.Pages.LibraryPage">
        <Border BorderThickness="2" BorderBrush="Aqua" CornerRadius="10" Margin="5" Background="#1A242D">
            <Grid>
                <Grid.RowDefinitions>
                   <RowDefinition Height="*"/>
                   <RowDefinition Height="*"/>
                   <RowDefinition Height="5*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Label HorizontalAlignment="Left">
                        <Viewbox Stretch="Uniform">
                            <StackPanel Orientation="Horizontal" Margin="5,0,0,0">
                                <material:MaterialIcon Kind="Book" Foreground="White"/>
                                <TextBlock Text="{DynamicResource Library}" Margin="5" Foreground="White"/>
                            </StackPanel>
                        </Viewbox>
                    </Label>
                </Grid>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="9*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Margin="10" HorizontalAlignment="Left" VerticalAlignment="Center"
                    BorderBrush="OrangeRed" BorderThickness="2" CornerRadius="5"
                    Padding="1">
                        <Viewbox Stretch="Uniform">
                            <TextBox Text="{Binding SearchText, Mode=TwoWay}"
                            Background="#1A242D" MaxLength="60"
                            Foreground="LightGray" Margin="3"
                            PlaceholderText="{DynamicResource Search}" PlaceholderForeground="White"
                            BorderBrush="#80ffffff"/>
                        </Viewbox>
                    </Border>
                    <Border Grid.Column="1" Margin="10" VerticalAlignment="Center" HorizontalAlignment="Center"
                    BorderBrush="OrangeRed" BorderThickness="2" 
                    CornerRadius="5" Padding="1">
                        <Viewbox Stretch="Uniform">
                            <Button Content="{DynamicResource AddGame}"
                            Margin="3" BorderBrush="#80ffffff" 
                            VerticalAlignment="Stretch"
                            Background="Aqua"
                            Foreground="Black"
                            Click="AddGameButton"/>
                        </Viewbox>
                    </Border>
                </Grid>
                <Border Grid.Row="2" Margin="5" Background="#1A242D"
                CornerRadius="10" BorderThickness="1" BorderBrush="#50ffffff">
                    <Border Margin="5" CornerRadius="10" ClipToBounds="True">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="5*"/>
                            </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#0a141d" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                    <Viewbox Stretch="Uniform" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                        <Grid Width="800" Height="50" ColumnDefinitions="6*, 4*, 4*, 13*">
                                            <Border Grid.Column="0" BorderBrush="#50FFFFFF" BorderThickness="0,0,1,0"
                                                    VerticalAlignment="Center" Margin="10, 5, 0, 5">
                                                <Viewbox Margin="8" HorizontalAlignment="Left">
                                                    <TextBlock Text="{DynamicResource Name}" FontSize="20" Foreground="White" Margin="0, 2, 0, 2"/>
                                                </Viewbox>
                                            </Border>
                                            <Border Grid.Column="1" BorderBrush="#50FFFFFF" BorderThickness="0,0,1,0"
                                                    VerticalAlignment="Center" Margin="10, 5, 0, 5">
                                                <Viewbox Stretch="Uniform" Margin="8" HorizontalAlignment="Left">
                                                    <TextBlock Text="{DynamicResource Genre}" FontSize="20" Foreground="White" Margin="0, 2, 0, 2"/>
                                                </Viewbox>
                                            </Border>
                                            <Border Grid.Column="2" BorderBrush="#50FFFFFF" BorderThickness="0,0,1,0"
                                                    VerticalAlignment="Center" Margin="10, 5, 0, 5">
                                                <Viewbox Stretch="Uniform" Margin="8" HorizontalAlignment="Left">
                                                    <TextBlock Text="{DynamicResource YourRate}" FontSize="20" Foreground="White" Margin="0, 2, 0, 2"/>
                                                </Viewbox>
                                            </Border>
                                            <Border Grid.Column="3" BorderBrush="#50FFFFFF"
                                                    VerticalAlignment="Center" Margin="10, 5, 0, 5">
                                                <Viewbox Stretch="Uniform" Margin="8" HorizontalAlignment="Left">
                                                    <TextBlock Text="{DynamicResource Actions}" FontSize="20" Foreground="White" Margin="0, 2, 0, 2"/>
                                                </Viewbox>
                                            </Border>
                                        </Grid>
                                    </Viewbox>
                                </Border>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding FilteredGames}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <gamelibrarymanager:GameUserControl/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Border>
            </Grid>
        </Border>
</UserControl>