<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <sys:String x:Key="Home"> Home</sys:String>
    <sys:String x:Key="Library">Library</sys:String>
    <sys:String x:Key="Settings"> Settings</sys:String>
    <sys:String x:Key="Exit"> Exit</sys:String>
    <sys:String x:Key="AddGame">+ Add Game</sys:String>
    <sys:String x:Key="Search">Search games...</sys:String>
    <sys:String x:Key="Name">Name</sys:String>
    <sys:String x:Key="Genre">Genre</sys:String>
    <sys:String x:Key="YourRate">Your Rate</sys:String>
    <sys:String x:Key="Actions">Actions</sys:String>
    <sys:String x:Key="Launch">Launch</sys:String>
    <sys:String x:Key="Edit">Edit</sys:String>
    <sys:String x:Key="Delete">Delete</sys:String>
    <sys:String x:Key="NameExists">Game with this name already exists!</sys:String>
    <sys:String x:Key="FillAllFields">Please fill in all fields!</sys:String>
    <sys:String x:Key="SelectGameFile">Select game file</sys:String>
    <sys:String x:Key="ExecutableFiles">Executable files</sys:String>
    <sys:String x:Key="AllFiles">All files</sys:String>
    <sys:String x:Key="GameFileNotFound">Game file not found!</sys:String>
    <sys:String x:Key="InterfaceLanguage">Interface Language</sys:String>
    <sys:String x:Key="WindowOpacity">Window Opacity</sys:String>
    <sys:String x:Key="Resolution">Resolution</sys:String>
    <sys:String x:Key="Fullscreen">Fullscreen</sys:String>
    <sys:String x:Key="LastLaunch">Last Launch</sys:String>
    <sys:String x:Key="Browse">Browse</sys:String>
    <sys:String x:Key="GameName">Game Name:</sys:String>
    <sys:String x:Key="GameGenre">Game Genre:</sys:String>
    <sys:String x:Key="GameRate">Your Rate:</sys:String>
    <sys:String x:Key="Confirm">Confirm</sys:String>
    <sys:String x:Key="Cancel">Cancel</sys:String>
    <sys:String x:Key="LaunchSortList">Last Launched Games</sys:String>
    <sys:String x:Key="TotalGamesCount">Total Games Count:</sys:String>
    <sys:String x:Key="FavouriteGamesCount">Favourite Games Count:</sys:String>
    <sys:String x:Key="RandomGame">Random Game</sys:String>
</ResourceDictionary>